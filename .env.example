# Optional: GitHub owner/repo override (must be two segments: owner/repo).
# On Vercel, VERCEL_GIT_REPO_OWNER + VERCEL_GIT_REPO_SLUG override the local fallback.
# Default fallback in code: docs/nomu.land → https://github.com/docs/nomu.land
# NEXT_PUBLIC_GITHUB_DOCS_REPO=docs/nomu.land

# Repo for “missing place” issue links in docs (place search / geodata). Defaults to larien/nomu.land.
# NEXT_PUBLIC_GITHUB_PLACES_REPO=your-org/nomu.land

# Optional: Firestore Admin for “Was this helpful?” vote counts (POST /api/docs-feedback)
# Use Vercel env vars; never commit real values to the public repo.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# PEM with literal \n newlines is fine in Vercel
FIREBASE_PRIVATE_KEY=
