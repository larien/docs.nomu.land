{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "docs.nomu.land: dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "PORT": "3004"
      }
    }
  ]
}
